{
  "manifest_version": 3,
  "name": "ShipProof Proof Collector",
  "description": "Capture social proof from anywhere on the web.",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "icon-32.png",
    "default_title": "ShipProof Proof Collector"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://api.shipproof.io/*",
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
